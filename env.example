# ============================================
# SHOPIFY CONFIGURATION (Required)
# ============================================

# Get these from Shopify Partner Dashboard → Apps → [Your App] → API credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# ============================================
# APP CONFIGURATION
# ============================================

# Environment: development or production
NODE_ENV=production

# Port (Railway sets this automatically — leave blank for Railway)
# PORT=3000

# ============================================
# WEBHOOK BASE URL (Optional but recommended)
# ============================================

# Your Railway deployment URL (no trailing slash)
# Used to auto-register Shopify webhooks after first token exchange.
# If not set, webhooks must be registered manually or via shopify.app.toml.
# Example: https://katicrm-oauth-middleware-production.up.railway.app
WEBHOOK_BASE_URL=https://your-app-name.up.railway.app

# ============================================
# BUBBLE.IO ENDPOINTS (Optional)
# ============================================

# Token exchange events (install/re-auth) are sent here:
# { shop, access_token, scope, status, source, installed_at }
BUBBLE_API_ENDPOINT=https://katicrm.com/api/1.1/wf/store_shopify_token

# Live Bubble workflow base URL (no trailing slash).
# Each Shopify webhook calls its own Bubble workflow directly with the raw Shopify body:
#   customers/create  → /wh_shopify_customer_created
#   customers/updated → /wh_shopify_customer_updated
#   orders/create     → /wh_shopify_order_created
#   orders/updated    → /wh_shopify_order_updated
#   products/update   → /wh_shopify_product_updated
#   app/uninstalled   → /wh_shopify_uninstall
BUBBLE_WF_BASE_URL=https://katicrm.com/api/1.1/wf

# Test/version-test Bubble workflow base URL (no trailing slash)
BUBBLE_WF_BASE_URL_TEST=https://katicrm.com/version-test/api/1.1/wf

# Set to "true" to route all webhook calls to the test version instead of live.
# Flip this in Railway to switch between test and live without changing URLs.
BUBBLE_USE_TEST=false

# ============================================
# GDPR COMPLIANCE WEBHOOKS (Required for App Store)
# ============================================

# Bubble workflow for customer data export requests
BUBBLE_GDPR_DATA_REQUEST=https://katicrm.com/api/1.1/wf/gdpr_data_request

# Bubble workflow for customer data deletion
BUBBLE_GDPR_CUSTOMER_REDACT=https://katicrm.com/api/1.1/wf/shopify_customers_redact

# Bubble workflow for shop data deletion (when app uninstalled)
BUBBLE_GDPR_SHOP_REDACT=https://katicrm.com/api/1.1/wf/gdpr_shop_redact

# ============================================
# REDIS (Optional — Recommended for Production)
# ============================================

# Redis connection URL for persistent token storage.
# If not set, falls back to in-memory (tokens lost on restart).
# Railway: Add a Redis database from the dashboard — URL is injected automatically.
# Format: redis://default:password@host:port
# REDIS_URL=redis://default:your-password@redis-host.railway.internal:6379

# ============================================
# REMOVE THESE FROM RAILWAY (no longer used)
# ============================================
# APP_URL
# ADMIN_PASSWORD
# SHOPIFY_SCOPES
# BUBBLE_SUCCESS_URL
# BUBBLE_ERROR_URL
# BUBBLE_LANDING_URL

# ============================================
# NOTES
# ============================================
# 1. Never commit this file with real values
# 2. In Railway, set these in the Variables dashboard
# 3. All URLs must use HTTPS in production
# 4. SHOPIFY_API_SECRET is extremely sensitive — guard carefully
# 5. Test with a development store before going live
# 6. REDIS_URL is auto-set by Railway when you add a Redis plugin
